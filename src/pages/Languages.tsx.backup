                        <span className="absolute -top-2 -right-2 px-2 py-0.5 bg-amber/20 text-amber text-[9px] font-mono uppercase tracking-wider border border-amber/30 rounded">
                          Coming Soon
                        </span>
                      ) : deck.new ? (
                        <span className="absolute -top-2 -right-2 px-2 py-0.5 bg-emerald-500/20 text-emerald-400 text-[9px] font-mono uppercase tracking-wider border border-emerald-500/30 rounded">
