                      <div className={`w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 ${pdf.exists ? 'bg-tomato/20' : 'bg-earth-muted/20'}`}>
                        <Eye className={`w-5 h-5 ${pdf.exists ? 'text-tomato' : 'text-earth-muted'}`} />
