                </h3>
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  {languageScripts.map(script => (
                    <button
                      key={script.name}
                      onClick={() => setSelectedScript(script)}
                      className="group flex items-center gap-4 p-4 bg-surface border border-moss rounded-lg transition-all text-left hover:border-olive-light hover:bg-deep-sage/30 cursor-pointer"
                    >
                      <div className="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 bg-tomato/20">
                        <Code className="w-5 h-5 text-tomato" />
                      </div>
                      <div className="flex-1 min-w-0">
                        <p className="font-sans text-sm font-medium text-cream group-hover:text-olive-light transition-colors truncate">
                          {script.name}
                        </p>
                        <p className="text-xs text-earth-muted mt-0.5 line-clamp-1">{script.description}</p>
                        <div className="flex items-center gap-2 mt-1">
                          <span className="text-[10px] font-mono px-1.5 py-0.5 rounded bg-olive/20 text-olive-light">
                            {script.language}
                          </span>
